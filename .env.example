# ── Base de données (PostgreSQL) ──
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ── JWT ──
JWT_SECRET="votre-secret-jwt-minimum-32-caracteres"
JWT_EXPIRES_IN="7d"

# ── Serveur ──
PORT=3001
NODE_ENV=development

# ── Frontend (CORS) ──
# Plusieurs URLs séparées par des virgules
FRONTEND_URL="https://votre-app.vercel.app,https://www.debathaiti.com"

# ── Anthropic (IA) ──
ANTHROPIC_API_KEY="sk-ant-..."

# ── Stripe (paiements) ──
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── MonCash (paiements locaux Haïti) ──
MONCASH_API_URL="https://moncashbutton.digicelhaiti.com/Api"
MONCASH_CLIENT_ID=""
MONCASH_SECRET_KEY=""

# ── Cloudinary (images/vidéos) ──
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Email (Resend) ──
RESEND_API_KEY="re_..."

# ── Redis (cache) ──
REDIS_URL="redis://localhost:6379"
